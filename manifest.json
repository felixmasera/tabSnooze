{
  "manifest_version": 3,
  "name": "TabSnooze",
  "short_name": "TabSnooze",
  "version": "1.0.1",
  "author": "Felix Masera",
  "description": "Tab manager that snoozes tabs for later. Close tabs now, get them back on schedule. Declutter your browser without losing tabs.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
