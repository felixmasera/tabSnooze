{
  "manifest_version": 3,
  "name": "TabSnooze",
  "short_name": "TabSnooze",
  "version": "1.0.0",
  "author": "Felix Masera",
  "description": "Snooze tabs for later — Today, This Week, Someday, or Daily. Keep your browser clean without losing anything important.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_badge_text": ""
  },
  "background": {
    "service_worker": "background/background.js",
    "scripts": ["background/background.js"]
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabsnooze@felixmasera",
      "strict_min_version": "109.0"
    }
  }
}
